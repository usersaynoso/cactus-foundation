# =============================================================================
# Cactus — Environment Variables Reference
# Copy this file to .env.local for local development.
# NEVER commit .env or .env.local to git.
# =============================================================================

# =============================================================================
# LOCAL DEVELOPMENT (running on localhost, not Vercel)
# -----------------------------------------------------------------------------
# Cactus detects "local-development mode" by the ABSENCE of Vercel's VERCEL=1
# variable (it is set automatically on Vercel, never locally). In this mode:
#   - the setup wizard SKIPS the Vercel connect step and reads config from here;
#   - the admin env editor is read-only (edit this file and restart to change);
#   - core/module updates and the redeploy buttons are hidden (deploy via git);
#   - media uploads need a storage provider configured (any S3-compatible one).
#
# For local development you can leave VERCEL_API_TOKEN and VERCEL_PROJECT_ID
# UNSET, and instead set these three directly:
#   DATABASE_URL          - your local Postgres or a Neon dev-branch URL
#   SESSION_SECRET        - openssl rand -base64 32
#   SITE_URL              - http://localhost:3000
#   NEXT_PUBLIC_SITE_URL  - http://localhost:3000  (must match SITE_URL)
# Then: npm run db:migrate && npm run dev
# =============================================================================

# =============================================================================
# REQUIRED — setup cannot proceed without these
# (On Vercel: DATABASE_URL + the two VERCEL_* vars. Locally: DATABASE_URL,
#  SESSION_SECRET and SITE_URL - see the LOCAL DEVELOPMENT block above.)
# =============================================================================

# PostgreSQL pooled connection string (Neon, Supabase, PgBouncer).
# Can be provisioned automatically during setup — see NEON_API_KEY below.
# Example: postgres://user:pass@host-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Secret for signing session tokens. Min 32 random characters.
# Generate: openssl rand -base64 32
SESSION_SECRET=

# The canonical public domain of this site. Used to derive the WebAuthn
# relying party ID. Cannot be changed after first passkey is registered.
# Example: https://example.com
SITE_URL=

# Public-facing version of SITE_URL (must match SITE_URL). Shown in the
# browser-side setup wizard so the admin can verify the domain is correct.
# Example: https://example.com
NEXT_PUBLIC_SITE_URL=

# Vercel REST API token. Required for Edge Config writes, deployment status
# checks, and writing DATABASE_URL automatically when using NEON_API_KEY.
# Create at: Vercel dashboard → Account Settings → Tokens
VERCEL_API_TOKEN=

# Vercel project ID. Find it at: Vercel dashboard → your project → Settings → General.
# Must be added to the project's env vars and a redeploy triggered before setup.
VERCEL_PROJECT_ID=

# =============================================================================
# OPTIONAL — setup proceeds without these; the relevant feature is disabled
# until the variable is set and the app is redeployed.
# =============================================================================

# --- Automatic database provisioning (gates one-click Neon DB creation during setup) ---
# Leave unset if you are supplying your own DATABASE_URL.
# Generate at: Neon console → Account Settings → API keys (https://console.neon.tech)
NEON_API_KEY=

# --- Email (gates password+email-OTP login, email verification, recovery) ---
# Provide either Brevo OR SMTP credentials; Brevo takes priority if both set.

BREVO_API_KEY=
# --- OR ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Media (gates all image upload, including logo/favicon) ---
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT=
# Full URL of the Cloudflare Worker that proxies B2 objects
CLOUDFLARE_WORKER_URL=
# Just the hostname part, used in next.config.ts remotePatterns
CLOUDFLARE_WORKER_HOSTNAME=

# --- GitHub integration (gates module/theme install and update) ---
# Option A: connect a GitHub App via Config → Integrations (recommended).
# Requires ENCRYPTION_KEY below; no token to rotate ever.
# Option B: personal access token (repo-read + repo-write scopes) - legacy fallback.
GITHUB_API_TOKEN=
# Your Cactus main repo (owner/repo format), e.g. "myorg/my-cactus-site"
# Required for committing module/theme submodules via the GitHub API.
GITHUB_REPO=
# Optional: owner/repo whose wiki to sync (defaults to GITHUB_REPO)
WIKI_SOURCE_REPO=
# 32-byte encryption key for GitHub App credentials stored in the database.
# Required to use the GitHub App connect flow (GITHUB_API_TOKEN still works without it).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# --- Vercel Edge Config (fast edge reads for admin path and site status) ---
# Edge Config read connection string (format: ecfg_xxxx)
EDGE_CONFIG=
# The Edge Config's own numeric ID (for writes via Vercel REST API)
VERCEL_EDGE_CONFIG_ID=
# Vercel webhook secret for deployment events (Pro/Enterprise only)
# If not set, status is checked lazily on next Modules/Themes page load
VERCEL_WEBHOOK_SECRET=

# --- Cloudflare Turnstile (gates bot protection on public forms) ---
# Without these, forms rely on rate limiting only
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Members system ---
# Public URL prefix for the member account area (login, registration, profile).
# Deploy-time only: changing it requires a redeploy, same as the admin path.
# Lowercase letters, numbers and hyphens, 3-64 characters. Default: account
MEMBER_AREA_PATH=account

# --- Error reporting ---
SENTRY_DSN=

# --- Shop module — Stripe (gates the Stripe payment method at checkout) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Shop module — PayPal (gates the PayPal payment method at checkout) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox # or live
# No env vars needed for the bank transfer or cash payment methods.

# --- Runtime environment (set automatically by Next.js) ---
# NODE_ENV=development
