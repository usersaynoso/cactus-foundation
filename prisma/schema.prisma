// Cactus Foundation — Prisma Schema
// All timestamps are stored in UTC.
// Run `npm run db:migrate` (prisma migrate dev) for local development.
// Never use db push — see AGENTS.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Authentication
// ---------------------------------------------------------------------------

model User {
  id                      String    @id @default(cuid())
  email                   String    @unique
  username                String    @unique
  displayName             String?
  passwordHash            String?
  roleId                  String
  role                    Role      @relation(fields: [roleId], references: [id])
  emailVerifiedAt         DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  suspendedAt             DateTime?
  acceptedPrivacyPolicyAt DateTime?
  totpSecretEncrypted     String?
  totpVerifiedAt          DateTime?
  totpLastStep            BigInt?
  // AES-256-GCM encrypted phone number (lib/crypto/secrets.ts). When set and an
  // SMS provider module is active, password-login OTPs go by text instead of email.
  smsOtpPhoneEncrypted    String?

  passkeys        Passkey[]
  sessions        Session[]
  trustedDevices  TrustedDevice[]
  emailChallenges EmailChallenge[]
  recoveryRequests RecoveryRequest[]
  infoPages       InfoPage[]
  mediaItems      Media[]
  consentRecords  ConsentRecord[]

  // email and username are already @unique, which builds a unique index that serves
  // every lookup. A second plain index on the same column bought nothing and cost a
  // write on every user update.
}

model Passkey {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String   @unique
  publicKey    Bytes
  counter      BigInt   @default(0)
  transports   String[]
  label        String?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model TrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

// Purpose values: 'login_otp' | 'verify_email' | 'recovery'
model EmailChallenge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  purpose   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, purpose])
  @@index([expiresAt])
}

model RecoveryRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)

  @@index([userId])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Roles and Permissions
// ---------------------------------------------------------------------------

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  isProtected Boolean  @default(false)
  createdAt   DateTime @default(now())

  users       User[]
  members     Member[]
  permissions RolePermission[]
}

// Registry of all permission keys. Core keys registered at startup;
// module keys registered when a module is installed.
model Permission {
  key         String  @id
  description String?
  // null = core CMS, otherwise the module name that registered this permission
  module      String?

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId        String
  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionKey String
  permission    Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@id([roleId, permissionKey])
}

// ---------------------------------------------------------------------------
// Site Configuration (single row, id = "singleton")
// ---------------------------------------------------------------------------

model SiteConfig {
  id                     String     @id @default("singleton")
  siteName               String     @default("My Cactus Site")
  tagline                String?
  description            String?
  timezone               String     @default("UTC")
  locale                 String     @default("en-GB")
  dateFormat             String     @default("DD/MM/YYYY")
  timeFormat             String     @default("HH:mm")
  adminPath              String     @unique
  setupCompleted         Boolean    @default(false)
  status                 SiteStatus @default(comingSoon)
  hideFromCrawlers       Boolean    @default(true)
  trustDeviceDays        Int        @default(28)
  // Core version whose starter layout templates were last seeded. Compared to
  // package.json version on request; a mismatch triggers refreshStarterLayouts.
  starterTemplatesVersion String?
  emailFromName          String?
  emailFromAddress       String?
  // 'brevo' | 'smtp'
  emailProvider          String?
  // Active media provider for new uploads. Null until an admin selects one.
  // MediaProviderKind (PROXIED/DIRECT) is a static app-code lookup, not a column.
  mediaProvider          MediaProviderType?
  // Lazy-load images below the fold on the public site (Settings > Media).
  // Defaults on: it's the right answer for almost every site. The Image block is
  // deliberately exempt either way - see ImageBlock in lib/puck/config.tsx.
  lazyLoadImages         Boolean    @default(true)
  privacyPolicyPageId    String?
  termsPageId            String?
  logoMediaId            String?
  // Optional dark-mode logo. Frontend swaps to this when the active theme is
  // dark (data-theme="dark"); falls back to logoMediaId when unset.
  logoDarkMediaId        String?
  faviconMediaId         String?
  // Optional dark-mode favicon. Served via a prefers-color-scheme media query,
  // so it follows the browser/OS dark setting (not the in-site theme toggle).
  faviconDarkMediaId     String?
  // Square source image the admin uploads on the Branding tab. The favicon,
  // Apple touch icon and PWA icons below are auto-generated from it on upload,
  // each still independently replaceable. Kept for reference / re-generation.
  appIconMediaId         String?
  appleTouchIconMediaId  String?
  webManifest192MediaId  String?
  webManifest512MediaId  String?
  // Web-app manifest / installable-app identity. Fall back to siteName and
  // white when unset (see lib/config/branding.ts).
  appName                String?
  appShortName           String?
  themeColor             String?
  backgroundColor        String?
  // Stale-row cleanup periods (days)
  sessionPurgeAfterDays  Int        @default(30)
  recoveryPurgeAfterDays Int        @default(7)
  // FK to Menu.id — nullable until admin creates and assigns a menu
  mainMenuId             String?
  // FK to InfoPage.id — nullable; when set, that page is served at /
  homepageId             String?
  // Set when a Vercel redeploy is in-flight; cleared when READY or dismissed
  pendingRedeployId      String?
  // When pendingRedeployId was set; drives the server-side time-box that auto-releases
  // the redeploy gate so admins are never trapped (NULL => treat as expired).
  pendingRedeployAt      DateTime?
  // Design tokens: colours, fonts, spacing, radius, shadows stored as JSON
  designTokens           Json?
  // Cookie consent banner config (null = banner not configured)
  consentBannerConfig    Json?
  // 'public' = stable releases only; 'beta' = pre-releases included
  coreUpdateChannel      String     @default("public")
  // Members system settings (null = defaults; see lib/members/config.ts)
  membersConfig          Json?
  // Admin sidebar customisation: per-item order, rename and visibility rules set
  // in Settings > Navigation (null = built-in defaults; see lib/nav/admin-menu.ts)
  adminMenuConfig        Json?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
}

enum SiteStatus {
  live
  comingSoon
  maintenance
}

// User-created colour presets for Styles > Colours. Shown in the preset bar
// before the hardcoded COLOUR_PRESETS defaults (lib/design/tokens.ts), which
// have no DB row and can't be overwritten/deleted through this model.
model UserColourPreset {
  id        String   @id @default(cuid())
  name      String   @unique
  // { primary: {light, dark}, linkColour, linkHoverColour, linkColourDark, linkHoverColourDark }
  tokens    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Info Pages
// ---------------------------------------------------------------------------

model InfoPage {
  id              String     @id @default(cuid())
  slug            String     @unique
  title           String
  body            String     @db.Text
  // 'markdown' uses body; 'builder' uses builderData
  bodyFormat      BodyFormat @default(markdown)
  // Puck Data JSON — only populated when bodyFormat = 'builder'. Working draft; autosave target.
  builderData     Json?
  // Live content — only Publish writes this. What the public sees when status = published.
  publishedData   Json?
  // When the current live version was published.
  publishedAt     DateTime?
  // Who published the current live version (no Prisma relation, mirrors ogImageId style).
  publishedById   String?
  // Capped array of past published versions, newest first, max 10.
  // Entry shape: { data, title, at, byId }
  history         Json?
  status          PageStatus @default(draft)
  metaDescription String?
  // FK to Media.id — nullable, no Prisma-level relation to avoid circular ref
  ogImageId       String?
  // Nullable so content survives if author deletes their account
  createdById     String?
  createdBy       User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  menuItems  MenuItem[]

  // slug is already @unique - see the note on User. Only status needs a plain index.
  @@index([status])
}

enum PageStatus {
  draft
  published
}

enum BodyFormat {
  markdown
  builder
}

// ---------------------------------------------------------------------------
// Media
// ---------------------------------------------------------------------------

// Media provider enum. PROXIED providers (B2, R2, S3, SPACES, WASABI, MINIO,
// VERCEL_BLOB, SUPABASE_STORAGE) are fetched and resized by the Cloudflare Worker.
// DIRECT providers (CLOUDINARY, IMAGEKIT) serve and transform from their own CDN.
// The PROXIED/DIRECT distinction lives in app code (lib/media/providers.ts), not here.
enum MediaProviderType {
  B2
  R2
  S3
  SPACES
  WASABI
  MINIO
  VERCEL_BLOB
  SUPABASE_STORAGE
  CLOUDINARY
  IMAGEKIT
}

model Media {
  id           String            @id @default(cuid())
  key          String            @unique
  // Which provider this item actually lives on right now. Set at upload time
  // from the active provider; only changed by a completed migration.
  provider     MediaProviderType
  url          String
  // Nullable so content survives if uploader deletes their account
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  altText      String?
  isDecorative Boolean  @default(false)
  // The filename the user uploaded, kept verbatim for display. The storage
  // `key` is deliberately mangled (nanoid prefix, sanitised, unique) so this is
  // the only place the human-readable name survives. Nullable: legacy rows and
  // generated files (icons, avatars, exports) have none — callers fall back to
  // the key's basename.
  originalName String?
  mimeType     String
  sizeBytes    Int
  // True once the item has been re-encoded to WebP in place by the media
  // library's optimise action (single or bulk). Drives the "Optimised" badge
  // and stops the item being offered for optimising a second time.
  optimised    Boolean  @default(false)
  // Which folder this item lives in. Null = the media library root. Folders are
  // "physical": the folder path is baked into the storage `key`/`url`, so moving
  // an item between folders relocates the blob and rewrites every reference to it.
  folderId     String?
  folder       Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags         MediaTag[]
  createdAt    DateTime @default(now())

  @@index([uploadedById])
  @@index([createdAt])
  @@index([provider])
  @@index([folderId])
}

// A folder in the media library. Folders nest (self-relation) to any depth; a
// null parentId is a root-level folder. The folder path (every ancestor name
// joined) is baked into each contained item's storage key, so renaming a folder
// or moving an item rebuilds keys and rewrites references. Deleting a folder
// cascades — its subfolders and every file inside are permanently removed.
model Folder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("FolderTree")
  media     Media[]
  createdAt DateTime @default(now())

  // Two folders can't share a name under the same parent. (Postgres treats NULL
  // parentId rows as distinct, so uniqueness among root folders is enforced in
  // application code as well.)
  @@unique([parentId, name])
  @@index([parentId])
}

// A freeform, cross-cutting label. Unlike a folder (one per item), a media item
// can carry many tags. Created on the fly when first typed.
model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  media     MediaTag[]
}

// Join row: which tags are on which media items.
model MediaTag {
  mediaId String
  tagId   String
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([mediaId, tagId])
  @@index([tagId])
}

// A media migration job moves every Media row not already on `toProvider`
// onto it. Exactly one job runs at a time (guarded by the global DeployLock-style
// pattern). Processed in small batches triggered by repeated client-side calls
// while the admin keeps the migration screen open — never a Cron job.
model MediaMigrationJob {
  id            String            @id @default(cuid())
  toProvider    MediaProviderType
  status        String            // pending | running | completed | failed | cancelled
  totalItems    Int
  migratedItems Int               @default(0)
  failedItemIds Json              @default("[]")
  cursor        String?
  startedAt     DateTime          @default(now())
  completedAt   DateTime?
  lastError     String?

  @@index([status])
  @@index([startedAt])
}

// ---------------------------------------------------------------------------
// Layouts
// ---------------------------------------------------------------------------

model Layout {
  id                String     @id @default(cuid())
  name              String
  // header | footer | infoPage | notFound | statusPage | <module-type>
  type              String     @default("infoPage")
  description       String?
  // Puck builder data for the body structure
  builderData       Json?
  // Live content — only a publish (status -> published) writes this.
  publishedData     Json?
  // When the current live version was published.
  publishedAt       DateTime?
  // Who published the current live version (no Prisma relation, mirrors InfoPage style).
  publishedById     String?
  // Capped array of past published versions, newest first, max 10.
  // Entry shape: { data, name, at, byId }
  history           Json?
  // { include: ConditionRule[], exclude: ConditionRule[] }
  displayConditions Json?
  // Manual tiebreaker when two layouts have the same specificity score
  priority          Int        @default(0)
  status            PageStatus @default(draft)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // resolveThemeLayout() filters on (type, status) and orders by (priority, updatedAt),
  // and it runs three times on every public page render - header, footer, body. Without
  // this the planner had nothing to work with and seq-scanned the table each time.
  @@index([type, status, priority, updatedAt])
}

// A reusable Puck block snapshot, saved from any page or layout editor and
// insertable back into any other. Single-tenant, no folders/categories.
model SavedBlock {
  id            String   @id @default(cuid())
  name          String
  // The Puck component type this snapshot was taken from (e.g. "Hero", "Card")
  componentType String
  // Full ComponentData blob (type + props), reinserted verbatim on use
  data          Json
  createdAt     DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Modules
// ---------------------------------------------------------------------------

model Module {
  id              String       @id @default(cuid())
  name            String       @unique
  repoUrl         String
  // Confirmed installed version - the tag of the build that is actually live.
  version         String
  // Target version while a deploy is in flight; promoted to `version` only once the
  // deploy succeeds, dropped on failure. null when not mid-update.
  pendingVersion  String?
  // Short unique namespace for this module's database tables
  tablePrefix     String       @unique
  status          ModuleStatus @default(pending_install)
  installedAt     DateTime     @default(now())
  lastError       String?
  lastCheckedAt   DateTime?
  // Set when a newer tagged release is available
  updateAvailable String?
  updateNotes     String?      @db.Text
  // 'public' = stable releases only; 'beta' = pre-releases included
  updateChannel   String       @default("public")
  // Parsed cactus.module.json stored at install time for runtime access (nav entries, permissions)
  manifest        Json?
  // Set the first time this module's default layouts are seeded (its code only
  // reaches the build after the install deploy, so seeding happens then, not at
  // install time). Never cleared: a module *update* redeploys through the same
  // path, and re-seeding would resurrect layouts the owner has since deleted.
  layoutsSeededAt DateTime?

  // Every request that resolves module route tiers, and every admin page load, filters
  // modules by status.
  @@index([status])
}

enum ModuleStatus {
  pending_install
  deploying
  pending_deploy
  active
  inactive
  failed
  update_available
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

model Notification {
  id                String           @id @default(cuid())
  type              NotificationType @default(deployment)
  title             String
  // For deployment type: array of { label, detail?, at } reasons
  reasons           Json?
  // Admin-relative "View X" target (e.g. "/config?tab=general"). null for deployment.
  link              String?
  // Idempotency handle for on-demand alerts (core-update, module-update:{id},
  // contact-form:messages). null for deployment notifications.
  dedupeKey         String?
  // null = unread (drives nav badge). Set when admin redeploys or manually marks read.
  readAt            DateTime?
  // null = deploy not yet initiated (this is the "open" notification reasons append to)
  deployInitiatedAt DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([type, deployInitiatedAt])
  @@index([readAt])
  @@index([dedupeKey])
}

enum NotificationType {
  deployment
  core_update
  module_update
  message
}

// Applied module SQL migrations, tracked separately from Prisma's own history.
// The module migration runner checks this before applying any SQL file.
model ModuleMigration {
  id            String   @id @default(cuid())
  moduleName    String
  migrationName String
  appliedAt     DateTime @default(now())
  checksum      String

  @@unique([moduleName, migrationName])
  @@index([moduleName])
}

// Singleton lock preventing two concurrent installs/updates
model DeployLock {
  id       String   @id @default("singleton")
  lockedAt DateTime @default(now())
  // moduleId or themeId holding the lock
  lockedBy String
}

// ---------------------------------------------------------------------------
// GitHub App Connection (singleton — one App per installation)
// ---------------------------------------------------------------------------
// Secrets are encrypted at rest using ENCRYPTION_KEY (AES-256-GCM).
// This is a deliberate exception to the "secrets stay in env vars" rule:
// the App's private key is generated at runtime during the connect flow
// and cannot be pasted into an env var ahead of time.

model GithubAppConnection {
  id                     String   @id @default(cuid())
  appId                  String
  appSlug                String
  installationId         String?
  installationAccount    String?
  privateKeyEncrypted    String   @db.Text
  webhookSecretEncrypted String?  @db.Text
  clientIdEncrypted      String?  @db.Text
  clientSecretEncrypted  String?  @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Menu Management
// ---------------------------------------------------------------------------

enum MenuItemType {
  PAGE
  EXTERNAL
  MODULE_ENTITY
}

// Per-item audience targeting for site navigation menus. Applied at resolve time
// (lib/menu/resolve.ts) against the current viewer, so a restricted item never
// reaches the served HTML. Hiding an item hides its whole subtree.
//   PUBLIC        - everyone (default; unchanged legacy behaviour)
//   AUTHENTICATED - any signed-in visitor (member or admin)
//   GUEST         - signed-out visitors only (e.g. a "Log in" link)
//   ADMIN         - admin staff only (an admin User session)
enum MenuItemVisibility {
  PUBLIC
  AUTHENTICATED
  GUEST
  ADMIN
}

model Menu {
  id        String     @id @default(cuid())
  name      String
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id           String       @id @default(cuid())
  menuId       String
  menu         Menu         @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       MenuItem?    @relation("MenuItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children     MenuItem[]   @relation("MenuItemChildren")
  type         MenuItemType
  pageId       String?
  page         InfoPage?    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  label        String?
  url          String?
  // MODULE_ENTITY target: moduleId is the module slug (e.g. "boards"), entityKind
  // a provider-defined kind (e.g. "board", "tag"), entityId the raw row id. No FK -
  // module tables live outside Prisma (see modules/*/migrations).
  moduleId     String?
  entityKind   String?
  entityId     String?
  openInNewTab Boolean      @default(false)
  visibility   MenuItemVisibility @default(PUBLIC)
  order        Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([menuId, pageId])
  @@index([menuId])
  @@index([pageId])
}

// ---------------------------------------------------------------------------
// Rate Limiting
// ---------------------------------------------------------------------------

// Lightweight in-database rate limiting.
// key format: "ip:<address>" or "account:<userId>"
// action: "login" | "register" | "recovery_request" | "email_code" | ...
model RateLimit {
  id          String   @id @default(cuid())
  key         String
  action      String
  attempts    Int      @default(1)
  windowStart DateTime @default(now())

  @@unique([key, action])
  @@index([windowStart])
}

// ---------------------------------------------------------------------------
// GDPR Consent Records (append-only audit log)
// ---------------------------------------------------------------------------

// action values: 'accept_all' | 'reject_all' | 'custom' | 'withdraw'
model ConsentRecord {
  id                String   @id @default(cuid())
  consentId         String
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  categoriesVersion Int
  decision          Json
  action            String
  ipTruncated       String?
  uaHash            String?
  createdAt         DateTime @default(now())

  @@index([consentId, createdAt])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// WebAuthn challenge store (transient, short-lived)
// ---------------------------------------------------------------------------

// Stores the challenge bytes between the options call and the verify call.
// Cleaned up after use or expiry.
model WebAuthnChallenge {
  id        String   @id @default(cuid())
  // null for new registrations during setup (no user yet), set after
  userId    String?
  // Set for member passkey flows instead of userId (Members system)
  memberId  String?
  challenge String   @unique
  // 'registration' | 'authentication' | 'member_registration' | 'member_authentication'
  purpose   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([memberId])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Members (frontend identity layer — fully separate from admin User auth)
// ---------------------------------------------------------------------------
// See MEMBERS_SPEC.md. All token columns store hashes only; raw tokens are
// never persisted. Members never share sessions, cookies, or tables with
// the admin User model.

enum MemberStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  DELETED
}

enum AvatarChoice {
  UPLOAD
  GRAVATAR
  GENERATED
}

enum TwoFactorMethod {
  EMAIL
  AUTHENTICATOR_APP
  SMS
}

enum NotificationChannel {
  EMAIL
}

enum DigestMode {
  INSTANT
  DAILY
  WEEKLY
  DISABLED
}

enum DataExportStatus {
  PENDING
  PROCESSING
  READY
  EXPIRED
}

model Member {
  id                        String       @id @default(cuid())
  email                     String       @unique
  // Stored lowercase; validated against the shared path/username blocklist
  username                  String       @unique
  displayName               String?
  // FK to Media.id — plain string, no Prisma relation (mirrors ogImageId style)
  avatarMediaId             String?
  avatarChoice              AvatarChoice @default(GENERATED)
  bio                       String?
  websiteUrl                String?
  trusted                   Boolean      @default(false)
  status                    MemberStatus @default(PENDING_VERIFICATION)
  // Assigned at registration to the site's protected "Members" role; nullable so
  // pre-existing rows (created before this field existed) don't need a backfill.
  roleId                    String?
  role                      Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  emailVerified             Boolean      @default(false)
  emailVerifiedAt           DateTime?
  // Recovery contact shown in the account Security section
  backupEmail               String?
  suspendedUntil            DateTime?
  suspensionReason          String?
  suspensionNotified        Boolean      @default(false)
  deletionRequestedAt       DateTime?
  deletionScheduledAt       DateTime?
  deletionExportReady       Boolean      @default(false)
  usernameChangedAt         DateTime?
  previousUsername          String?
  previousUsernameExpiresAt DateTime?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  passkeys           MemberPasskey[]
  password           MemberPassword?
  sessions           MemberSession[]
  twoFactorConfigs   MemberTwoFactor[]
  trustedBrowsers    MemberTrustedBrowser[]
  magicLinks         MemberMagicLink[]
  verificationTokens MemberVerificationToken[]
  emailChallenges    MemberEmailChallenge[]
  recoveryCodes      MemberRecoveryCode[]
  notificationPrefs  MemberNotificationPreference[]
  consentRecords     MemberConsentRecord[]
  dataExportRequests MemberDataExportRequest[]
  activityEvents     MemberActivityEvent[]
  profileVisibility  MemberProfileVisibility?
  adminNotes         MemberAdminNote[]
  adminActionLogs    MemberAdminActionLog[]

  @@index([status])
  @@index([previousUsername])
  @@index([deletionScheduledAt])
  @@index([createdAt])
}

model MemberPasskey {
  id           String    @id @default(cuid())
  memberId     String
  member       Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  transports   String[]
  deviceName   String?
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([memberId])
}

model MemberPassword {
  id        String   @id @default(cuid())
  memberId  String   @unique
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  hash      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MemberTwoFactor {
  id              String          @id @default(cuid())
  memberId        String
  member          Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)
  method          TwoFactorMethod
  // AES-256-GCM encrypted TOTP secret (lib/crypto/secrets.ts); null for EMAIL method
  secretEncrypted String?
  // AES-256-GCM encrypted phone number; set only for the SMS method
  phoneEncrypted  String?
  verified        Boolean         @default(false)
  // TOTP replay guard — last accepted time step (mirrors User.totpLastStep)
  lastStep        BigInt?
  createdAt       DateTime        @default(now())

  @@unique([memberId, method])
}

model MemberTrustedBrowser {
  id         String   @id @default(cuid())
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  deviceInfo String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([memberId])
  @@index([expiresAt])
}

model MemberSession {
  id           String   @id @default(cuid())
  memberId     String
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tokenHash    String   @unique
  ipAddress    String?
  userAgent    String?
  location     String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([memberId])
  @@index([expiresAt])
}

model MemberMagicLink {
  id        String    @id @default(cuid())
  memberId  String
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  expiresAt DateTime

  @@index([memberId])
  @@index([expiresAt])
}

model MemberVerificationToken {
  id        String    @id @default(cuid())
  memberId  String
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  expiresAt DateTime

  @@index([memberId])
  @@index([expiresAt])
}

// 2FA email codes for members (mirrors EmailChallenge, which FKs User)
// Purpose values: 'login_2fa' | 'setup_2fa'
model MemberEmailChallenge {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  codeHash  String
  purpose   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([memberId, purpose])
  @@index([expiresAt])
}

// One-time recovery codes, shown once at generation and stored hashed
model MemberRecoveryCode {
  id        String    @id @default(cuid())
  memberId  String
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([memberId])
}

model MemberNotificationPreference {
  id         String              @id @default(cuid())
  memberId   String
  member     Member              @relation(fields: [memberId], references: [id], onDelete: Cascade)
  channel    NotificationChannel @default(EMAIL)
  // Core or module-registered category key (e.g. "forum:replies")
  category   String
  digestMode DigestMode          @default(INSTANT)
  enabled    Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([memberId, channel, category])
}

model MemberConsentRecord {
  id          String   @id @default(cuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  consentType String
  granted     Boolean
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([memberId])
  @@index([createdAt])
}

model MemberDataExportRequest {
  id          String           @id @default(cuid())
  memberId    String
  member      Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  status      DataExportStatus @default(PENDING)
  // FK to Media.id — plain string, no Prisma relation (mirrors ogImageId style)
  mediaId     String?
  // Download availability cut-off (48 hours after READY)
  expiresAt   DateTime?
  createdAt   DateTime         @default(now())
  completedAt DateTime?

  @@index([memberId])
  @@index([status])
}

model MemberActivityEvent {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  // Core type (e.g. 'login') or module-registered type key
  type      String
  // null = core; otherwise the module name that emitted the event
  source    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([memberId, createdAt(sort: Desc)])
}

model MemberProfileVisibility {
  id           String  @id @default(cuid())
  memberId     String  @unique
  member       Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  showBio      Boolean @default(true)
  showJoinDate Boolean @default(true)
  showWebsite  Boolean @default(true)
}

// Single-use registration invites for INVITE_ONLY mode
model MemberInvite {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  // Admin User.id — plain string, survives via snapshot if the admin goes
  createdById    String?
  createdByName  String?
  usedAt         DateTime?
  usedByMemberId String?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime

  @@index([expiresAt])
}

// Append-only internal admin notes on a member (never edited after save)
model MemberAdminNote {
  id         String   @id @default(cuid())
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  // Admin User.id + display-name snapshot (no relation; survives admin deletion)
  authorId   String?
  authorName String?
  body       String   @db.Text
  createdAt  DateTime @default(now())

  @@index([memberId, createdAt(sort: Desc)])
}

// Audit log of admin actions taken on a member (suspend, approve, edit, …)
model MemberAdminActionLog {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  actorId   String?
  actorName String?
  action    String
  detail    Json?
  createdAt DateTime @default(now())

  @@index([memberId, createdAt(sort: Desc)])
}

// Admin overrides for member email templates; absence of a row = code default
// (registry in lib/email/templates.ts). Reset-to-default deletes the row.
model EmailTemplate {
  id          String   @id @default(cuid())
  // e.g. "member.verify-email"
  key         String   @unique
  subject     String
  bodyHtml    String   @db.Text
  updatedById String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}
