// Cactus Foundation — Prisma Schema
// All timestamps are stored in UTC.
// Run `npm run db:migrate` (prisma migrate dev) for local development.
// Never use db push — see AGENTS.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Authentication
// ---------------------------------------------------------------------------

model User {
  id                      String    @id @default(cuid())
  email                   String    @unique
  username                String    @unique
  displayName             String?
  passwordHash            String?
  roleId                  String
  role                    Role      @relation(fields: [roleId], references: [id])
  emailVerifiedAt         DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  suspendedAt             DateTime?
  acceptedPrivacyPolicyAt DateTime?

  passkeys        Passkey[]
  sessions        Session[]
  trustedDevices  TrustedDevice[]
  emailChallenges EmailChallenge[]
  recoveryRequests RecoveryRequest[]
  infoPages       InfoPage[]
  mediaItems      Media[]
  consentRecords  ConsentRecord[]

  @@index([email])
  @@index([username])
}

model Passkey {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String   @unique
  publicKey    Bytes
  counter      BigInt   @default(0)
  transports   String[]
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model TrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

// Purpose values: 'login_otp' | 'verify_email' | 'recovery'
model EmailChallenge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  purpose   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, purpose])
  @@index([expiresAt])
}

model RecoveryRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)

  @@index([userId])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Roles and Permissions
// ---------------------------------------------------------------------------

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  isProtected Boolean  @default(false)
  createdAt   DateTime @default(now())

  users       User[]
  permissions RolePermission[]
}

// Registry of all permission keys. Core keys registered at startup;
// module keys registered when a module is installed.
model Permission {
  key         String  @id
  description String?
  // null = core CMS, otherwise the module name that registered this permission
  module      String?

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId        String
  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionKey String
  permission    Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@id([roleId, permissionKey])
}

// ---------------------------------------------------------------------------
// Site Configuration (single row, id = "singleton")
// ---------------------------------------------------------------------------

model SiteConfig {
  id                     String     @id @default("singleton")
  siteName               String     @default("My Cactus Site")
  tagline                String?
  description            String?
  timezone               String     @default("UTC")
  locale                 String     @default("en-GB")
  dateFormat             String     @default("DD/MM/YYYY")
  timeFormat             String     @default("HH:mm")
  adminPath              String     @unique
  setupCompleted         Boolean    @default(false)
  status                 SiteStatus @default(comingSoon)
  hideFromCrawlers       Boolean    @default(true)
  publicRegistration     Boolean    @default(true)
  defaultRoleId          String?
  trustDeviceDays        Int        @default(28)
  emailFromName          String?
  emailFromAddress       String?
  // 'brevo' | 'smtp'
  emailProvider          String?
  // Active media provider for new uploads. Null until an admin selects one.
  // MediaProviderKind (PROXIED/DIRECT) is a static app-code lookup, not a column.
  mediaProvider          MediaProviderType?
  privacyPolicyPageId    String?
  termsPageId            String?
  logoMediaId            String?
  faviconMediaId         String?
  // Stale-row cleanup periods (days)
  sessionPurgeAfterDays  Int        @default(30)
  recoveryPurgeAfterDays Int        @default(7)
  // FK to Menu.id — nullable until admin creates and assigns a menu
  mainMenuId             String?
  // FK to InfoPage.id — nullable; when set, that page is served at /
  homepageId             String?
  // Set when a Vercel redeploy is in-flight; cleared when READY or dismissed
  pendingRedeployId      String?
  // Design tokens: colours, fonts, spacing, radius, shadows stored as JSON
  designTokens           Json?
  // Cookie consent banner config (null = banner not configured)
  consentBannerConfig    Json?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
}

enum SiteStatus {
  live
  comingSoon
  maintenance
}

// ---------------------------------------------------------------------------
// Info Pages
// ---------------------------------------------------------------------------

model InfoPage {
  id              String     @id @default(cuid())
  slug            String     @unique
  title           String
  body            String     @db.Text
  // 'markdown' uses body; 'builder' uses builderData
  bodyFormat      BodyFormat @default(markdown)
  // Puck Data JSON — only populated when bodyFormat = 'builder'
  builderData     Json?
  status          PageStatus @default(draft)
  metaDescription String?
  // FK to Media.id — nullable, no Prisma-level relation to avoid circular ref
  ogImageId       String?
  // Nullable so content survives if author deletes their account
  createdById     String?
  createdBy       User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  menuItems  MenuItem[]

  @@index([slug])
  @@index([status])
}

enum PageStatus {
  draft
  published
}

enum BodyFormat {
  markdown
  builder
}

// ---------------------------------------------------------------------------
// Media
// ---------------------------------------------------------------------------

// Media provider enum. PROXIED providers (B2, R2, S3, SPACES, WASABI, MINIO,
// VERCEL_BLOB, SUPABASE_STORAGE) are fetched and resized by the Cloudflare Worker.
// DIRECT providers (CLOUDINARY, IMAGEKIT) serve and transform from their own CDN.
// The PROXIED/DIRECT distinction lives in app code (lib/media/providers.ts), not here.
enum MediaProviderType {
  B2
  R2
  S3
  SPACES
  WASABI
  MINIO
  VERCEL_BLOB
  SUPABASE_STORAGE
  CLOUDINARY
  IMAGEKIT
}

model Media {
  id           String            @id @default(cuid())
  key          String            @unique
  // Which provider this item actually lives on right now. Set at upload time
  // from the active provider; only changed by a completed migration.
  provider     MediaProviderType
  url          String
  // Nullable so content survives if uploader deletes their account
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  altText      String?
  isDecorative Boolean  @default(false)
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime @default(now())

  @@index([uploadedById])
  @@index([createdAt])
  @@index([provider])
}

// A media migration job moves every Media row not already on `toProvider`
// onto it. Exactly one job runs at a time (guarded by the global DeployLock-style
// pattern). Processed in small batches triggered by repeated client-side calls
// while the admin keeps the migration screen open — never a Cron job.
model MediaMigrationJob {
  id            String            @id @default(cuid())
  toProvider    MediaProviderType
  status        String            // pending | running | completed | failed | cancelled
  totalItems    Int
  migratedItems Int               @default(0)
  failedItemIds Json              @default("[]")
  cursor        String?
  startedAt     DateTime          @default(now())
  completedAt   DateTime?
  lastError     String?

  @@index([status])
  @@index([startedAt])
}

// ---------------------------------------------------------------------------
// Layouts
// ---------------------------------------------------------------------------

model Layout {
  id                String     @id @default(cuid())
  name              String
  // header | footer | infoPage | notFound | statusPage | <module-type>
  type              String     @default("infoPage")
  description       String?
  // Puck builder data for the body structure
  builderData       Json?
  // { include: ConditionRule[], exclude: ConditionRule[] }
  displayConditions Json?
  // Manual tiebreaker when two layouts have the same specificity score
  priority          Int        @default(0)
  // Starter layouts are seeded and cannot be deleted by users
  isStarter         Boolean    @default(false)
  status            PageStatus @default(draft)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

// ---------------------------------------------------------------------------
// Modules
// ---------------------------------------------------------------------------

model Module {
  id              String       @id @default(cuid())
  name            String       @unique
  repoUrl         String
  version         String
  // Short unique namespace for this module's database tables
  tablePrefix     String       @unique
  status          ModuleStatus @default(pending_install)
  installedAt     DateTime     @default(now())
  lastError       String?
  lastCheckedAt   DateTime?
  // Set when a newer tagged release is available
  updateAvailable String?
  updateNotes     String?      @db.Text
  // Parsed cactus.module.json stored at install time for runtime access (nav entries, permissions)
  manifest        Json?
}

enum ModuleStatus {
  pending_install
  deploying
  active
  inactive
  failed
  update_available
}

// Applied module SQL migrations, tracked separately from Prisma's own history.
// The module migration runner checks this before applying any SQL file.
model ModuleMigration {
  id            String   @id @default(cuid())
  moduleName    String
  migrationName String
  appliedAt     DateTime @default(now())
  checksum      String

  @@unique([moduleName, migrationName])
  @@index([moduleName])
}

// Singleton lock preventing two concurrent installs/updates
model DeployLock {
  id       String   @id @default("singleton")
  lockedAt DateTime @default(now())
  // moduleId or themeId holding the lock
  lockedBy String
}

// ---------------------------------------------------------------------------
// GitHub App Connection (singleton — one App per installation)
// ---------------------------------------------------------------------------
// Secrets are encrypted at rest using ENCRYPTION_KEY (AES-256-GCM).
// This is a deliberate exception to the "secrets stay in env vars" rule:
// the App's private key is generated at runtime during the connect flow
// and cannot be pasted into an env var ahead of time.

model GithubAppConnection {
  id                     String   @id @default(cuid())
  appId                  String
  appSlug                String
  installationId         String?
  installationAccount    String?
  privateKeyEncrypted    String   @db.Text
  webhookSecretEncrypted String?  @db.Text
  clientIdEncrypted      String?  @db.Text
  clientSecretEncrypted  String?  @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Menu Management
// ---------------------------------------------------------------------------

enum MenuItemType {
  PAGE
  EXTERNAL
}

model Menu {
  id        String     @id @default(cuid())
  name      String
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id           String       @id @default(cuid())
  menuId       String
  menu         Menu         @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       MenuItem?    @relation("MenuItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children     MenuItem[]   @relation("MenuItemChildren")
  type         MenuItemType
  pageId       String?
  page         InfoPage?    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  label        String?
  url          String?
  openInNewTab Boolean      @default(false)
  order        Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([menuId, pageId])
  @@index([menuId])
  @@index([pageId])
}

// ---------------------------------------------------------------------------
// Rate Limiting
// ---------------------------------------------------------------------------

// Lightweight in-database rate limiting.
// key format: "ip:<address>" or "account:<userId>"
// action: "login" | "register" | "recovery_request" | "email_code" | ...
model RateLimit {
  id          String   @id @default(cuid())
  key         String
  action      String
  attempts    Int      @default(1)
  windowStart DateTime @default(now())

  @@unique([key, action])
  @@index([windowStart])
}

// ---------------------------------------------------------------------------
// GDPR Consent Records (append-only audit log)
// ---------------------------------------------------------------------------

// action values: 'accept_all' | 'reject_all' | 'custom' | 'withdraw'
model ConsentRecord {
  id                String   @id @default(cuid())
  consentId         String
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  categoriesVersion Int
  decision          Json
  action            String
  ipTruncated       String?
  uaHash            String?
  createdAt         DateTime @default(now())

  @@index([consentId, createdAt])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// WebAuthn challenge store (transient, short-lived)
// ---------------------------------------------------------------------------

// Stores the challenge bytes between the options call and the verify call.
// Cleaned up after use or expiry.
model WebAuthnChallenge {
  id        String   @id @default(cuid())
  // null for new registrations during setup (no user yet), set after
  userId    String?
  challenge String   @unique
  // 'registration' | 'authentication'
  purpose   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
