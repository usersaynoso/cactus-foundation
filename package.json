{
  "name": "cactus",
  "version": "0.1.10",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && node scripts/build-migrate.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:push": "echo 'Use prisma migrate dev instead of db push — see AGENTS.md' && exit 1",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:status": "prisma migrate status"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "@prisma/client": "^6.0.0",
    "@simplewebauthn/browser": "^13.0.0",
    "@simplewebauthn/server": "^13.0.0",
    "@vercel/edge-config": "^1.0.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "marked": "^15.0.0",
    "dompurify": "^3.0.0",
    "jsdom": "^25.0.0",
    "nodemailer": "^6.9.0",
    "bcryptjs": "^2.4.3",
    "nanoid": "^5.0.0",
    "zod": "^3.23.0",
    "date-fns": "^4.0.0",
    "date-fns-tz": "^3.0.0",
    "sharp": "^0.33.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "prisma": "^6.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@types/pg": "^8.11.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
