    "@imagekit/nodejs": "^7.8.1",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^21.0.0",
    "@prisma/client": "^6.0.0",
    "@puckeditor/core": "^0.22.0",
    "@simplewebauthn/browser": "^13.0.0",
    "@simplewebauthn/server": "^13.0.0",
    "@supabase/storage-js": "^2.108.2",
    "@types/aos": "^3.0.8",
    "@vercel/blob": "^2.4.1",
    "@vercel/edge-config": "^1.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "aos": "^2.3.4",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "date-fns": "^4.0.0",
    "date-fns-tz": "^3.0.0",
    "dompurify": "^3.0.0",
    "email-reply-parser": "^2.3.5",
    "imapflow": "^1.4.3",
    "jsdom": "^26.1.0",
    "mailparser": "^3.9.12",
    "marked": "^15.0.0",
    "nanoid": "^5.0.0",
    "next": "^16.0.0",
    "nodemailer": "^6.9.0",
    "otpauth": "^9.5.1",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.0",
    "shiki": "^3.23.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "prisma": "^6.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
