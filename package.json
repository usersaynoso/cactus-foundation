{
  "name": "cactus",
  "version": "0.5.189",
  "private": true,
  "scripts": {
    "dev": "node scripts/generate-module-router.mjs && node scripts/generate-module-puck.mjs && node scripts/generate-module-cron.mjs && node scripts/generate-module-settings-tabs.mjs && node scripts/generate-module-extension-points.mjs && next dev --webpack",
    "dev:warm": "bash scripts/dev-warm.sh",
    "build": "node scripts/checkout-modules.mjs && prisma generate && node scripts/build-migrate.mjs && node scripts/sync-module-manifests.mjs && node scripts/generate-module-router.mjs && node scripts/generate-module-puck.mjs && node scripts/generate-module-cron.mjs && node scripts/generate-module-settings-tabs.mjs && node scripts/generate-module-extension-points.mjs && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:push": "echo 'Use prisma migrate dev instead of db push — see AGENTS.md' && exit 1",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:status": "prisma migrate status",
    "sync-wiki": "node scripts/sync-wiki.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
